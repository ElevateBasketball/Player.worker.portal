<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Elevate Basketball</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;font-size:14px;background:#111;color:#e8e8e8;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:1.5rem}
.wrap{width:100%;max-width:360px;text-align:center}
.logo{font-size:52px;margin-bottom:10px}
.title{font-size:26px;font-weight:700;margin-bottom:4px}
.title span{color:#7ab8f0}
.sub{font-size:13px;color:#666;margin-bottom:48px}
.prompt{font-size:15px;color:#999;margin-bottom:18px;font-weight:500}
.choices{display:flex;flex-direction:column;gap:12px}
.choice{display:block;width:100%;text-align:left;padding:18px 20px;border-radius:14px;border:1px solid #2e2e2e;background:#1a1a1a;cursor:pointer;text-decoration:none;color:#e8e8e8;transition:background 0.15s,border-color 0.15s}
.choice:hover{background:#222;border-color:#444}
.choice-icon{font-size:28px;margin-bottom:6px}
.choice-label{font-size:16px;font-weight:600;margin-bottom:3px}
.choice-desc{font-size:12px;color:#666}
.choice.worker{border-color:#1a4a8a}
.choice.worker:hover{border-color:#7ab8f0;background:#0c2040}
.choice.player{border-color:#1a5a20}
.choice.player:hover{border-color:#60c070;background:#0a2010}

/* Frame container styling to cleanly embed your views */
.view-frame {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  border: none;
  background: #111;
  z-index: 9999;
}
.view-frame.active {
  display: block;
}
</style>
</head>
<body>

<div class="wrap">
  <div class="logo">🏀</div>
  <div class="title"><span>Elevate</span> Basketball</div>
  <div class="sub">Training Portal</div>
  <div class="prompt">I am a...</div>
  <div class="choices">
    
    <button class="choice worker" onclick="openPortal('worker-view.html')">
      <div class="choice-icon">👷</div>
      <div class="choice-label">Worker</div>
      <div class="choice-desc">View shifts, set availability</div>
    </button>
    
    <button class="choice player" onclick="openPortal('player-view.html')">
      <div class="choice-icon">⛹️</div>
      <div class="choice-label">Player</div>
      <div class="choice-desc">View sessions, set availability</div>
    </button>
    
  </div>
</div>

<iframe id="portal-frame" class="view-frame"></iframe>

<script>
function openPortal(url) {
  const frame = document.getElementById('portal-frame');
  frame.src = url;
  frame.classList.
