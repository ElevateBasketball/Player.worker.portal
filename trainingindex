<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal Selection</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');
        body {
            font-family: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="bg-slate-900 text-white min-h-screen flex flex-col items-center justify-center p-6">

    <!-- Header / Welcome -->
    <div class="text-center mb-12">
        <h1 class="text-4xl font-bold tracking-tight mb-3 bg-gradient-to-r from-blue-400 to-emerald-400 bg-clip-text text-transparent">
            Welcome to the Portal
        </h1>
        <p class="text-slate-400 text-lg">Please select your role to continue</p>
    </div>

    <!-- Selection Cards Container -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl w-full">
        
        <!-- Coach Portal Card -->
        <a href="coach.html" class="group relative bg-slate-800/50 border border-slate-700/50 rounded-2xl p-8 text-center transition-all duration-300 hover:scale-[1.02] hover:bg-slate-800 hover:border-blue-500/50 hover:shadow-[0_0_30px_rgba(59,130,246,0.2)]">
            <div class="mx-auto w-16 h-16 bg-blue-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-blue-500/20 transition-colors">
                <!-- Whistle / Strategy Icon -->
                <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
            </div>
            <h2 class="text-2xl font-semibold mb-2 group-hover:text-blue-400 transition-colors">Coach Portal</h2>
            <p class="text-slate-400 text-sm leading-relaxed">
                Manage teams, track athlete performance, analyze data, and build training regimens.
            </p>
            <div class="mt-6 inline-flex items-center text-sm font-semibold text-blue-400 group-hover:underline">
                Enter Dashboard &rarr;
            </div>
        </a>

        <!-- Player Portal Card -->
        <a href="player.html" class="group relative bg-slate-800/50 border border-slate-700/50 rounded-2xl p-8 text-center transition-all duration-300 hover:scale-[1.02] hover:bg-slate-800 hover:border-emerald-500/50 hover:shadow-[0_0_30px_rgba(16,185,129,0.2)]">
            <div class="mx-auto w-16 h-16 bg-emerald-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-emerald-500/20 transition-colors">
                <!-- Athlete / Training Icon -->
                <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
            </div>
            <h2 class="text-2xl font-semibold mb-2 group-hover:text-emerald-400 transition-colors">Player Portal</h2>
            <p class="text-slate-400 text-sm leading-relaxed">
                View your personal stats, complete assigned training modules, and track your development.
            </p>
            <div class="mt-6 inline-flex items-center text-sm font-semibold text-emerald-400 group-hover:underline">
                Enter Dashboard &rarr;
            </div>
        </a>

    </div>

    <!-- Optional Footer -->
    <div class="mt-16 text-xs text-slate-600">
        &copy; 2026 Sports Performance Platform. All rights reserved.
    </div>

</body>
</html>
